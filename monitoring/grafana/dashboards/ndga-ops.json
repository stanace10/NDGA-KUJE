{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "stat",
      "title": "App Ready",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "ndga_ready", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN"}, "1": {"text": "READY"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}
    },
    {
      "type": "stat",
      "title": "Sync Backlog",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "ndga_sync_backlog", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "CBT Failures 24h",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "ndga_cbt_runner_failures_last_24h", "refId": "A"}]
    },
    {
      "type": "stat",
      "title": "Celery Broker",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "ndga_celery_broker_reachable", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}
    },
    {
      "type": "timeseries",
      "title": "Sync Queue By Status",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "ndga_sync_queue_items", "legendFormat": "{{status}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Celery Queue Depth",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [{"expr": "ndga_celery_queue_depth", "legendFormat": "{{queue}}", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "Disk Free GB",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{"expr": "ndga_disk_free_gigabytes", "refId": "A"}]
    },
    {
      "type": "timeseries",
      "title": "CBT Failure Totals",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "ndga_cbt_runner_failures_total", "legendFormat": "total", "refId": "A"},
        {"expr": "ndga_cbt_runner_failures_last_24h", "legendFormat": "last_24h", "refId": "B"}
      ]
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["ndga", "ops"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "title": "NDGA Ops",
  "uid": "ndga-ops",
  "version": 1
}
