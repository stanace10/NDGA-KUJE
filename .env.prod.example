EXAM_SAFE_MODE=1
DJANGO_SETTINGS_MODULE=core.settings.prod
DJANGO_SECRET_KEY=replace-with-existing-secret-from-env-lan
DJANGO_ALLOWED_HOSTS=192.168.10.10,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://192.168.10.10,https://192.168.10.10
DB_NAME=ndga
DB_USER=ndga
DB_PASSWORD=replace-with-existing-database-password
DB_HOST=pgbouncer
DB_PORT=6432
DATABASE_CONN_MAX_AGE=0
POSTGRES_MAX_CONNECTIONS=80
POSTGRES_SHARED_BUFFERS=3GB
POSTGRES_EFFECTIVE_CACHE_SIZE=8GB
POSTGRES_WORK_MEM=16MB
POSTGRES_MAINTENANCE_WORK_MEM=512MB
POSTGRES_CHECKPOINT_TIMEOUT=15min
POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
POSTGRES_MAX_WAL_SIZE=4GB
POSTGRES_MIN_WAL_SIZE=1GB
POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=30s
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_DEFAULT_POOL_SIZE=40
PGBOUNCER_MIN_POOL_SIZE=10
PGBOUNCER_RESERVE_POOL_SIZE=15
PGBOUNCER_RESERVE_POOL_TIMEOUT=5
PGBOUNCER_MAX_DB_CONNECTIONS=60
REDIS_STATE_URL=redis://redis_state:6379/0
REDIS_BROKER_URL=redis://redis_broker:6379/0
REDIS_CACHE_URL=redis://redis_broker:6379/1
CELERY_BROKER_URL=redis://redis_broker:6379/0
CELERY_RESULT_BACKEND=redis://redis_broker:6379/3
CHANNEL_REDIS_URL=redis://redis_broker:6379/2
GUNICORN_WORKER_CLASS=gthread
GUNICORN_WORKERS=4
GUNICORN_THREADS=8
GUNICORN_BACKLOG=4096
GUNICORN_KEEPALIVE=5
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_MAX_REQUESTS=5000
GUNICORN_MAX_REQUESTS_JITTER=500
NGINX_WORKER_CONNECTIONS=4096
NGINX_UPSTREAM_KEEPALIVE=64
RATE_LIMIT_LOGIN_LIMIT=500
LOCKDOWN_HEARTBEAT_INTERVAL_SECONDS=15
