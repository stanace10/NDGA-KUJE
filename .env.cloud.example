DJANGO_SETTINGS_MODULE=core.settings.prod
DJANGO_SECRET_KEY=replace-with-a-strong-cloud-secret
DJANGO_ALLOWED_HOSTS=ndgakuje.org,www.ndgakuje.org,student.ndgakuje.org,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://ndgakuje.org,https://www.ndgakuje.org,https://student.ndgakuje.org
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

SYNC_NODE_ROLE=CLOUD
CLOUD_STAFF_OPERATIONS_LAN_ONLY=True
CLOUD_STUDENT_PORTAL_LIMITED=True
CLOUD_STUDENT_FINANCE_DISABLED=True
STUDENT_FEE_STATUS_AVAILABLE=False
LAN_RUNTIME_RESTRICT_PORTALS=False

DB_NAME=ndga
DB_USER=ndga
DB_PASSWORD=replace-with-cloud-database-password
DB_HOST=db
DB_PORT=5432
DATABASE_CONN_MAX_AGE=0

REDIS_URL=redis://redis:6379/0
REDIS_STATE_URL=redis://redis:6379/0
REDIS_BROKER_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/3
CHANNEL_REDIS_URL=redis://redis:6379/2
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

GUNICORN_WORKER_CLASS=gthread
GUNICORN_WORKERS=3
GUNICORN_THREADS=8
GUNICORN_BACKLOG=2048
GUNICORN_KEEPALIVE=5
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_MAX_REQUESTS=3000
GUNICORN_MAX_REQUESTS_JITTER=300

CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_MAX_TASKS_PER_CHILD=500

MEDIA_STORAGE_BACKEND=filesystem
MANUAL_UPDATE_REMOTE_BASE_URL=https://student.ndgakuje.org
MANUAL_UPDATE_TOKEN=replace-with-the-same-manual-update-token-used-on-lan

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=office@ndgakuje.org
