NDGA_ENV_FILE=.env.cloud
DJANGO_SETTINGS_MODULE=core.settings.prod
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=ndgakuje.org,.ndgakuje.org
DJANGO_CSRF_TRUSTED_ORIGINS=https://ndgakuje.org,https://*.ndgakuje.org
DJANGO_TIME_ZONE=Africa/Lagos
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
SESSION_COOKIE_DOMAIN=.ndgakuje.org

DB_ENGINE=django.db.backends.postgresql
DB_NAME=ndga
DB_USER=ndga
DB_PASSWORD=
DB_HOST=db
DB_PORT=5432
DATABASE_CONN_MAX_AGE=60

REDIS_CACHE_URL=redis://redis:6379/1
CHANNEL_REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CACHE_BACKEND=redis
CHANNEL_LAYER_BACKEND=redis

CBT_ENABLED=True
ELECTION_ENABLED=True
OFFLINE_MODE_ENABLED=True
LOCKDOWN_ENABLED=True
SYNC_LOCAL_NODE_ENABLED=True
SYNC_LOCAL_NODE_ID=ndga-cloud-node
SYNC_NODE_ROLE=CLOUD
SYNC_CLOUD_ENDPOINT=
SYNC_ENDPOINT_AUTH_TOKEN=
SYNC_MAX_RETRIES=8
SYNC_RETRY_BASE_SECONDS=20
SYNC_RETRY_MAX_SECONDS=1800
SYNC_CONNECTIVITY_TIMEOUT_SECONDS=2
SYNC_AUTO_ON_REQUEST=True
SYNC_AUTO_MIN_INTERVAL_SECONDS=5
SYNC_PROCESS_BEAT_INTERVAL_SECONDS=5
SYNC_PULL_ENABLED=False
SYNC_PULL_BATCH_LIMIT=200
SYNC_PULL_MAX_PAGES_PER_RUN=4
SYNC_PULL_TIMEOUT_SECONDS=5
SYNC_PULL_BEAT_INTERVAL_SECONDS=5
SYNC_ENFORCE_ACTIVE_SESSION_AUTHORITY=True

GRADE_OVERRIDE_REQUIRES_ELEVATED_APPROVAL=False
PRINCIPAL_OVERRIDE_ENABLED=True
IT_BOOTSTRAP_USERNAME=admin@ndgakuje.org

NDGA_LOCAL_SIMPLE_HOST_MODE=False
NDGA_BASE_DOMAIN=ndgakuje.org
NDGA_LANDING_HOST=ndgakuje.org
NDGA_STUDENT_HOST=student.ndgakuje.org
NDGA_STAFF_HOST=staff.ndgakuje.org
NDGA_IT_HOST=it.ndgakuje.org
NDGA_BURSAR_HOST=bursar.ndgakuje.org
NDGA_VP_HOST=vp.ndgakuje.org
NDGA_PRINCIPAL_HOST=principal.ndgakuje.org
NDGA_CBT_HOST=cbt.ndgakuje.org
NDGA_ELECTION_HOST=election.ndgakuje.org

MEDIA_STORAGE_BACKEND=s3
AWS_STORAGE_BUCKET_NAME=ndgakuje-media
AWS_S3_REGION_NAME=eu-north-1
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_FILE_OVERWRITE=False
AWS_QUERYSTRING_AUTH=False

NOTIFICATIONS_EMAIL_PROVIDER=brevo
NOTIFICATIONS_FROM_EMAIL=admin@ndgakuje.org
BREVO_API_KEY=
BREVO_SENDER_NAME=NOTRE DAME GIRLS ACADEMY

